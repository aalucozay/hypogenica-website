# Contact form email delivery (optional).
# Without these, the contact form falls back to opening the visitor's mail app.

# Resend API key — enables server-side email delivery for the contact form.
RESEND_API_KEY=

# Where contact submissions are delivered (defaults to info@hypogenica.com).
CONTACT_TO_EMAIL=info@hypogenica.com

# Verified sender address. Must be on a domain verified in Resend.
# Defaults to Resend's shared test sender if unset.
CONTACT_FROM_EMAIL=Hypogenica <onboarding@resend.dev>
